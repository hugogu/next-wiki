{
  "name": "next-wiki",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @next-wiki/web exec drizzle-kit generate",
    "db:migrate": "pnpm --filter @next-wiki/web exec drizzle-kit migrate",
    "db:studio": "pnpm --filter @next-wiki/web exec drizzle-kit studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  }
}
