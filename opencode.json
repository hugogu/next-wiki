{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "next-wiki": {
      "type": "local",
      "command": ["npx", "-y", "@next-wiki/mcp-server"],
      "environment": {
        "NEXT_WIKI_API_URL": "{env:NEXT_WIKI_API_URL}",
        "NEXT_WIKI_API_KEY": "{env:NEXT_WIKI_API_KEY}"
      },
      "enabled": true
    }
  },
  "tools": {
    "next-wiki_*": true
  },
  "instructions": ["CLAUDE.md"]
}
