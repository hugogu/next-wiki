# ─────────────────────────────────────────────────────────────────────────────
# next-wiki Environment Configuration
# Copy this file to .env and fill in required values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=nextwiki
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nextwiki
POSTGRES_PORT=5432

# Full connection URL (used by app; assembled from above for docker-compose)
DATABASE_URL=postgresql://nextwiki:changeme@localhost:5432/nextwiki

# ── Application ──────────────────────────────────────────────────────────────
APP_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── Encryption ───────────────────────────────────────────────────────────────
# Used to encrypt auth provider credentials stored in the database.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Asset Storage ─────────────────────────────────────────────────────────────
ASSET_STORAGE_PATH=./data/assets

# ── AI (Optional) ─────────────────────────────────────────────────────────────
# Leave blank to disable AI features entirely.
# Supported providers: openai, anthropic, ollama, or any OpenAI-compatible API.
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ── Background Jobs ───────────────────────────────────────────────────────────
# pg-boss uses the same DATABASE_URL above. No separate config needed.

# ── Observability (Optional) ──────────────────────────────────────────────────
LOG_LEVEL=info
