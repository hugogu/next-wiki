    "@types/node": "^22.10.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
