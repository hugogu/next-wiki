{
  "name": "@next-wiki/mcp-server",
  "version": "0.1.5",
  "description": "MCP Server for next-wiki. Exposes the v1 Public Wiki Content API as MCP tools and resources.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/hugogu/next-wiki.git",
    "directory": "packages/mcp-server"
  },
  "bin": {
    "next-wiki-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
